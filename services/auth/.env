PORT=8001
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=socraticmind_auth
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secrets (change in production!)
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-use-256-bit-random
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-use-256-bit-random
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Internal
INTERNAL_API_KEY=dev-internal-key-change-in-production
